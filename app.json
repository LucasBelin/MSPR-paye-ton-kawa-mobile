      },
      "package": "com.lucasbelin.MSPRpayetonkawamobile"
    },
    "config": {
      "plugins": ["./plugins/withDisableForcedDarkModeAndroid.js", {}]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "dc0c15b2-7e98-4bcb-a6dd-d6025055ef26"
      }
    }
  }
